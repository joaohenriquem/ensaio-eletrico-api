{
  "name": "ensaio-eletrico-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/static dist/static",
    "start": "node --dns-result-order=ipv4first dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1049.0",
    "@hono/node-server": "^1.13.7",
    "@supabase/supabase-js": "^2.106.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "hono": "^4.6.10",
    "jose": "^5.9.6",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.15.0",
    "pg": "^8.13.1",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.13.6",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
